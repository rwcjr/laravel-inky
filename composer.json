{
  "name": "valliance/laravel-inky",
  "description": "Foundation Inky email templates in Laravel",
  "keywords": [
    "foundation",
    "inky",
    "laravel"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Cody Carrell",
      "email": "nysos3@gmail.com"
    }
  ],
  "require": {
    "nysos3/inky": "^1.3.10",
    "illuminate/support": "~5.7|~6.0|~7.0|~8.0|~9.0|~10.0|^11.0|^12.0",
    "illuminate/view": "~5.7|~6.0|~7.0|~8.0|~9.0|~10.0|^11.0|^12.0",
    "symfony/css-selector": "~2.7|~3.0|~4.0|~5.0|~6.0",
    "symfony/dom-crawler": "~2.7|~3.0|~4.0|~5.0|~6.0",
    "tijsverkoyen/css-to-inline-styles": "^2.2"
  },
  "require-dev": {
    "graham-campbell/testbench": "~3.3|~4.0|~5.7|~6.0",
    "phpunit/phpunit": "~5.4|~10.0",
    "mockery/mockery": "^0.9.5|~1.6"
  },
  "autoload": {
    "psr-4": {
      "Petecoop\\LaravelInky\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Petecoop\\Tests\\LaravelInky\\": "tests"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Petecoop\\LaravelInky\\InkyServiceProvider"
      ]
    }
  }
}
